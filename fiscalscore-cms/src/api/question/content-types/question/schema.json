{
  "kind": "collectionType",
  "collectionName": "questions",
  "info": {
    "singularName": "question",
    "pluralName": "questions",
    "displayName": "Question",
    "description": "Single questionnaire question"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "texte": {
      "type": "text",
      "required": true
    },
    "critere": {
      "type": "string"
    },
    "indicateur": {
      "type": "text"
    },
    "ordre": {
      "type": "integer"
    },
    "commentaireZero": {
      "type": "text"
    },
    "commentaireUn": {
      "type": "text"
    },
    "commentaireDeux": {
      "type": "text"
    },
    "commentaireTrois": {
      "type": "text"
    },
    "questionnaire": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::questionnaire.questionnaire",
      "inversedBy": "questions"
    }
  }
}
