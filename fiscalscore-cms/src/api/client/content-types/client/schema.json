{
  "kind": "collectionType",
  "collectionName": "clients",
  "info": {
    "singularName": "client",
    "pluralName": "clients",
    "displayName": "Client",
    "description": "Fiscal client record"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nom": {
      "type": "string",
      "required": true
    },
    "prenom": {
      "type": "string",
      "required": true
    },
    "identifiantFiscal": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "email": {
      "type": "email"
    },
    "telephone": {
      "type": "string"
    },
    "score": {
      "type": "integer",
      "default": 0
    },
    "statut": {
      "type": "enumeration",
      "enum": ["Critique", "Risque élevé", "Moyen", "Bon", "Excellent"],
      "default": "Moyen"
    },
    "evaluations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::evaluation.evaluation",
      "mappedBy": "client"
    }
  }
}
