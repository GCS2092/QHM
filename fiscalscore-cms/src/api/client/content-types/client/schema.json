{
  "kind": "collectionType",
  "collectionName": "clients",
  "info": {
    "singularName": "client",
    "pluralName": "clients",
    "displayName": "Client",
    "description": "Fiscal client record"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "nomEntreprise": {
      "type": "string",
      "required": true
    },
    "nomResponsable": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "telephone": {
      "type": "string"
    },
    "secteur": {
      "type": "string"
    },
    "archive": {
      "type": "boolean",
      "default": false
    },
    "assignations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::assignation.assignation",
      "mappedBy": "client"
    },
    "evaluations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::evaluation.evaluation",
      "mappedBy": "client"
    }
  }
}