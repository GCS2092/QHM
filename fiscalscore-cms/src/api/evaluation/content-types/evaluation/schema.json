{
  "kind": "collectionType",
  "collectionName": "evaluations",
  "info": {
    "singularName": "evaluation",
    "pluralName": "evaluations",
    "displayName": "Evaluation",
    "description": "Fiscal evaluation record"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "scoreFinal": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "scoreMaxReel": {
      "type": "integer",
      "default": 0
    },
    "pourcentageScore": {
      "type": "integer",
      "default": 0
    },
    "dateEvaluation": {
      "type": "date",
      "required": true
    },
    "evaluateur": {
      "type": "string",
      "required": true
    },
    "evaluateurUtilisateur": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "commentaireGlobal": {
      "type": "text"
    },
    "commentaireConclusion": {
      "type": "text"
    },
    "statut": {
      "type": "enumeration",
      "enum": ["en_cours", "terminee"],
      "default": "en_cours"
    },
    "client": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::client.client",
      "inversedBy": "evaluations"
    },
    "questionnaire": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::questionnaire.questionnaire",
      "inversedBy": "evaluations"
    },
    "reponses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::reponse.reponse",
      "mappedBy": "evaluation"
    },
    "questions_custom": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::question-custom.question-custom",
      "mappedBy": "evaluation"
    }
  }
}
