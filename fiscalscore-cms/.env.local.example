# Strapi v5 - Configuration PostgreSQL
# Copier ce fichier en .env.local et remplir vos valeurs

# ============================================
# DATABASE - PostgreSQL Configuration
# ============================================

# Connection type
DATABASE_CLIENT=postgres

# Host de la base de données
DATABASE_HOST=localhost

# Port PostgreSQL (par défaut: 5432)
DATABASE_PORT=5432

# Nom de la base de données
DATABASE_NAME=fiscalscore

# Utilisateur PostgreSQL
DATABASE_USERNAME=strapi

# Mot de passe PostgreSQL
DATABASE_PASSWORD=your_actual_password_here

# URL complète (alternative)
# DATABASE_URL=postgres://strapi:password@localhost:5432/fiscalscore

# SSL Configuration (optionnel)
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Schéma PostgreSQL (optionnel, par défaut: public)
DATABASE_SCHEMA=public

# Pool de connexions
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000

# ============================================
# Application Configuration
# ============================================

# Node environment
NODE_ENV=development

# Admin URL
ADMIN_JWT_SECRET=your_super_secret_key_change_me

# API Token encryption
API_TOKEN_SALT=your_token_salt_change_me

# ============================================
# Migration Scripts Configuration
# ============================================

# Ces variables sont utilisées par les scripts:
# - scripts/migrate-strapi-v5-documentids.js
# - scripts/check-database-schema.js
# - scripts/rollback-migration.js

# Les variables DATABASE_* ci-dessus sont utilisées automatiquement
